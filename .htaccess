DirectoryIndex index.php
Options -Indexes

<IfModule mod_mime.c>
    AddType font/ttf .ttf
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block executable or internal files in public asset directories.
    RewriteRule ^assets/.*\.(?:php[0-9]?|phtml|phar|sql)$ - [F,L,NC]
    RewriteRule ^modules/[a-z][a-z0-9_]{1,39}/assets/.*\.(?:php[0-9]?|phtml|phar|sql)$ - [F,L,NC]

    # Allow public static assets.
    RewriteRule ^assets/ - [L]
    RewriteRule ^modules/[a-z][a-z0-9_]{1,39}/assets/ - [L]
    RewriteRule ^modules/ckeditor/vendor/ckeditor5/ckeditor5\.(?:umd\.js|css)$ - [L]
    RewriteRule ^storage/cache/thumbnails/[a-f0-9]{2}/[a-f0-9]{64}_[A-Za-z0-9_]+_[0-9]+\.(?:jpe?g|png|gif|webp)$ - [L,NC]
    RewriteRule ^storage/cache/thumbnails/[a-z][a-z0-9_]{1,39}/[a-f0-9]{2}/[a-f0-9]{64}_[A-Za-z0-9_]+_[a-f0-9]{16,64}\.(?:jpe?g|png|gif|webp)$ - [L,NC]

    # Block internal project directories.
    RewriteRule ^(?:config|core|database|docs|examples|storage|modules|\.git|\.tools|\.claude)(?:/|$) - [F,L]

    # Block root-only project metadata files.
    RewriteRule ^(?:AGENTS\.md|README\.md|LICENSE|\.gitignore|\.htaccess|\.env(?:\..*)?)$ - [F,L]

    # Route virtual application paths to the front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
